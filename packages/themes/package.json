{
  "name": "@zeus-web/themes",
  "type": "module",
  "version": "0.0.0",
  "description": "Theme tokens for Zeus Web.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baicie/zeus-ui.git",
    "directory": "packages/themes"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": [
    "./src/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./default.css": "./dist/default.css",
    "./slate.css": "./dist/slate.css",
    "./zinc.css": "./dist/zinc.css",
    "./neutral.css": "./dist/neutral.css",
    "./stone.css": "./dist/stone.css",
    "./components.css": "./dist/components.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --clean --watch",
    "build": "tsup src/index.ts --format esm --dts --clean && tsx scripts/copy-css.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --root ../.. --project unit packages/themes/__tests__/themes.spec.ts"
  }
}
