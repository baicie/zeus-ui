{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchPackagePatterns": ["^@zeus-js/"],
      "groupName": "zeus packages",
      "rangeStrategy": "pin",
      "automerge": false,
      "labels": ["dependencies", "zeus"]
    }
  ]
}
