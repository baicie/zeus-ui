{
  "$schema": "https://raw.githubusercontent.com/webcomponents/custom-elements-json/main/packages/custom-elements-json/schema.json",
  "version": "1.0.0",
  "module": "./dist/wc.js",
  "declarations": [
    {
      "kind": "class",
      "name": "ZeusInputElement",
      "tagName": "zw-input",
      "customElement": true,
      "attributes": [
        {
          "name": "value",
          "type": { "text": "string" }
        },
        {
          "name": "type",
          "type": { "text": "string" }
        },
        {
          "name": "placeholder",
          "type": { "text": "string" }
        },
        {
          "name": "disabled",
          "type": { "text": "boolean" }
        },
        {
          "name": "readonly",
          "type": { "text": "boolean" }
        },
        {
          "name": "required",
          "type": { "text": "boolean" }
        },
        {
          "name": "name",
          "type": { "text": "string" }
        }
      ],
      "events": [
        {
          "name": "value-change",
          "type": {
            "text": "CustomEvent<{ value: string; nativeEvent: Event }>"
          }
        }
      ]
    }
  ]
}
