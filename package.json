{
  "name": "zeus-ui-workspace",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=18.12.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter './packages/**' dev",
    "build": "tsx scripts/commands/build.ts",
    "clean": "rimraf --glob 'packages/**/dist' --glob 'apps/**/.vitepress/dist' --glob 'examples/**/dist' --glob 'examples/**/.next' temp node_modules/.cache",
    "check": "tsc -p tsconfig.json --incremental --noEmit",
    "check:zeus-baseline": "tsx scripts/checks/contract/check-zeus-baseline.ts",
    "check:zeus-workspace": "tsx scripts/checks/check-zeus-workspace.ts",
    "check:zeus-imports": "tsx scripts/checks/check-zeus-imports.ts",
    "check:exports": "tsx scripts/checks/build/check-package-exports.ts",
    "check:build-output": "tsx scripts/checks/build/check-build-output.ts",
    "check:workspace-overrides": "tsx scripts/checks/check-workspace-overrides.ts",
    "showcase:ci:unit": "pnpm showcase:test",
    "showcase:ci:build": "pnpm showcase:build",
    "showcase:ci:e2e": "pnpm showcase:e2e",
    "zeus:relax-peer-ranges": "tsx scripts/commands/relax-zeus-peer-ranges.ts",
    "zeus:update-canary": "tsx scripts/commands/update-zeus-canary.ts",
    "lint": "eslint --cache --cache-location node_modules/.cache/.eslintcache .",
    "lint-fix": "eslint --fix --cache --cache-location node_modules/.cache/.eslintcache .",
    "format": "prettier --write --cache --cache-location node_modules/.cache/.prettiercache .",
    "format-check": "prettier --check --cache --cache-location node_modules/.cache/.prettiercache .",
    "test": "vitest",
    "build:examples": "tsx scripts/examples/build-showcase-deps.ts",
    "test-unit": "pnpm build:examples && vitest --project unit* --run",
    "test-coverage": "vitest run --project unit* --coverage",
    "release": "tsx scripts/commands/release.ts",
    "release:dry": "tsx scripts/commands/release.ts --dry-run",
    "release:plan": "tsx scripts/commands/release-plan.ts",
    "release:verify": "tsx scripts/checks/release/check-release-readiness.ts",
    "release:verify:strict": "tsx scripts/checks/release/check-release-readiness.ts --strict",
    "release:verify:pack": "tsx scripts/checks/release/check-release-tarballs.ts",
    "release:final": "tsx scripts/checks/release/check-release-final.ts",
    "version:packages": "tsx scripts/commands/version-packages.ts",
    "ci-publish": "tsx scripts/commands/publish.ts",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks",
    "docs:dev": "vitepress dev apps/docs",
    "docs:build": "vitepress build apps/docs",
    "docs:preview": "vitepress preview apps/docs",
    "docs:generate": "tsx scripts/commands/generate-docs.ts",
    "docs:check-generated": "tsx scripts/checks/docs/check-generated-docs.ts",
    "check:public-docs": "tsx scripts/checks/docs/check-public-docs.ts",
    "docs:check-playground": "tsx scripts/checks/docs/check-playground.ts",
    "docs:check": "pnpm docs:check-generated && tsx scripts/checks/docs/check-docs.ts && pnpm check:public-docs && pnpm docs:check-playground && pnpm --filter \"@zeus-web/docs\" check",
    "docs:build:deps": "pnpm showcase:e2e:deps",
    "docs:ci": "pnpm docs:build:deps && pnpm docs:check && pnpm docs:build",
    "examples:contract": "tsx scripts/checks/examples/check-examples.ts",
    "examples:check": "pnpm examples:contract && pnpm -F \"@zeus-web/example-*\" --filter=\"!@zeus-web/example-next-app\" --workspace-concurrency=1 check",
    "examples:build": "pnpm -F \"@zeus-web/example-*\" --filter=\"!@zeus-web/example-next-app\" build",
    "showcase:react": "pnpm --filter @zeus-web/example-react-showcase dev",
    "showcase:vue": "pnpm --filter @zeus-web/example-vue-showcase dev",
    "showcase:native": "pnpm --filter @zeus-web/example-native-showcase dev",
    "showcase:advanced": "pnpm --filter @zeus-web/example-advanced-showcase dev",
    "showcase:build": "pnpm --filter @zeus-web/example-react-showcase build && pnpm --filter @zeus-web/example-vue-showcase build && pnpm --filter @zeus-web/example-native-showcase build && pnpm --filter @zeus-web/example-advanced-showcase build",
    "showcase:test": "pnpm showcase:test:react && pnpm showcase:test:vue && pnpm showcase:test:native && pnpm showcase:test:advanced",
    "showcase:test:react": "pnpm --filter @zeus-web/example-react-showcase test",
    "showcase:test:vue": "pnpm --filter @zeus-web/example-vue-showcase test",
    "showcase:test:native": "pnpm --filter @zeus-web/example-native-showcase test",
    "showcase:test:advanced": "pnpm --filter @zeus-web/example-advanced-showcase test",
    "showcase:test:coverage": "pnpm --filter @zeus-web/example-react-showcase test -- --coverage && pnpm --filter @zeus-web/example-vue-showcase test -- --coverage && pnpm --filter @zeus-web/example-native-showcase test -- --coverage && pnpm --filter @zeus-web/example-advanced-showcase test -- --coverage",
    "showcase:e2e:deps": "pnpm -w exec tsx scripts/examples/build-showcase-deps.ts --force",
    "showcase:e2e": "pnpm showcase:e2e:deps && vitest --project showcase-e2e --run",
    "showcase:e2e:ui": "pnpm showcase:e2e:deps && vitest --project showcase-e2e --ui",
    "showcase:e2e:headed": "pnpm showcase:e2e:deps && SHOWCASE_E2E_HEADLESS=false vitest --project showcase-e2e --run",
    "showcase:registry:sync": "tsx scripts/examples/sync-showcase-registry.ts",
    "showcase:registry:check": "tsx scripts/examples/sync-showcase-registry.ts --check",
    "check:component-coverage": "tsx scripts/checks/registry/check-component-coverage.ts",
    "check:showcase-metadata": "tsx scripts/checks/examples/check-showcase-metadata.ts",
    "check:showcase-implementation": "tsx scripts/checks/examples/check-showcase-implementation.ts",
    "check:product-layers": "tsx scripts/checks/contract/check-product-layers.ts",
    "check:ui-package": "tsx scripts/checks/contract/check-ui-package.ts",
    "check:product-contract": "tsx scripts/checks/contract/check-product-contract.ts && pnpm check:advanced-contract && pnpm check:chat-product-contract && pnpm check:data-grid-product-contract && pnpm check:revogrid-adapter-product-contract && pnpm check:agent-console-product-contract && pnpm check:advanced-final-contract",
    "check:advanced-contract": "tsx scripts/checks/contract/check-advanced-contract.ts",
    "check:chat-product-contract": "tsx scripts/checks/contract/check-chat-product-contract.ts",
    "check:data-grid-product-contract": "tsx scripts/checks/contract/check-data-grid-product-contract.ts",
    "check:revogrid-adapter-product-contract": "tsx scripts/checks/contract/check-revogrid-adapter-product-contract.ts",
    "check:agent-console-product-contract": "tsx scripts/checks/contract/check-agent-console-product-contract.ts",
    "check:advanced-final-contract": "tsx scripts/checks/contract/check-advanced-final-contract.ts",
    "showcase:ci:metadata": "pnpm check:component-coverage && pnpm check:showcase-metadata && pnpm check:showcase-implementation && pnpm check:product-contract && pnpm docs:check",
    "showcase:ci": "pnpm showcase:ci:metadata && pnpm showcase:test && pnpm showcase:build && pnpm showcase:e2e",
    "site:check": "pnpm check:component-coverage && pnpm check:showcase-metadata && pnpm check:showcase-implementation && pnpm check:product-layers && pnpm check:ui-package && pnpm check:product-contract && pnpm docs:check && pnpm docs:build && pnpm examples:check && pnpm showcase:test",
    "site:build": "pnpm docs:build && pnpm examples:build",
    "link:zeus-js": "tsx scripts/commands/link-local-zeus.ts",
    "unlink:zeus-js": "tsx scripts/commands/unlink-local-zeus.ts && pnpm install"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@babel/core": "^8.0.1",
    "@baicie/release": "^0.4.0",
    "@baicie/scripts": "^0.1.2",
    "@playwright/test": "^1.61.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-vue": "^6.0.7",
    "@zeus-js/bundler-plugin": "0.1.0-beta.5",
    "@zeus-js/compiler": "0.1.0-beta.5",
    "@zeus-js/component-analyzer": "0.1.0-beta.5",
    "@zeus-js/component-dts": "0.1.0-beta.5",
    "@zeus-js/output-icons": "0.1.0-beta.5",
    "@zeus-js/output-react-wrapper": "0.1.0-beta.5",
    "@zeus-js/output-vue-wrapper": "0.1.0-beta.5",
    "@zeus-js/output-wc": "0.1.0-beta.5",
    "@zeus-js/runtime-dom": "0.1.0-beta.5",
    "@zeus-js/signal": "0.1.0-beta.5",
    "@zeus-js/zeus": "0.1.0-beta.5",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "execa": "^9.6.1",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "rolldown": "^1.1.2",
    "rollup": "^4.62.2",
    "simple-git-hooks": "^2.13.1",
    "tslib": "^2.8.1",
    "tsup": "8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9",
    "vue": "^3.5.38"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm check",
    "commit-msg": "node -e \"import('@baicie/scripts').then(m => m.verifyCommit())\""
  },
  "lint-staged": {
    "*.{js,json,md,ts,tsx,yaml,yml}": [
      "prettier --write --cache --cache-location node_modules/.cache/.prettiercache"
    ],
    "*.ts?(x)": [
      "eslint --fix --cache --cache-location node_modules/.cache/.eslintcache",
      "prettier --parser=typescript --write --cache --cache-location node_modules/.cache/.prettiercache"
    ]
  }
}
