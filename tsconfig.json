{
  "extends": "./scripts/config/tsconfig.base.json",
  "compilerOptions": {
    "types": ["vitest/globals", "node"],
    "noEmit": true,
    "outDir": "temp",
    "isolatedDeclarations": false,
    "skipLibCheck": true
  },
  "include": [
    "scripts/config/jsx.d.ts",
    "packages/*/src",
    "packages/primitives/*/src",
    "packages/advanced/*/src",
    "packages/advanced/*/benchmarks",
    "packages/*/__tests__",
    "packages/primitives/*/__tests__",
    "packages/advanced/*/__tests__",
    "scripts/**/*",
    "apps/**/*",
    "examples/showcase-shared/src/**/*",
    "e2e/**/*"
  ],
  "exclude": ["packages/zeus-compat/__tests__/canary-capabilities.spec.ts"]
}
