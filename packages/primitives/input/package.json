{
  "name": "@zeus-web/input",
  "type": "module",
  "version": "0.0.0",
  "description": "Headless input primitive for Zeus Web.",
  "license": "MIT",
  "sideEffects": [
    "./dist/wc.js",
    "./dist/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wc": {
      "types": "./dist/wc.d.ts",
      "import": "./dist/wc.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    },
    "./custom-elements.json": {
      "default": "./custom-elements.json"
    }
  },
  "files": [
    "custom-elements.json",
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts src/wc.ts src/react.ts src/vue.ts --format esm --dts --clean --watch",
    "build": "tsup src/index.ts src/wc.ts src/react.ts src/vue.ts --format esm --dts --clean",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
